# .env.example — copy to .env and fill in real values

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── LM Studio ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=lm-studio
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_MODEL=local-model
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT_MS=30000

# ─── Bitrix24 ─────────────────────────────────────────────────────────────────
# Incoming webhook URL (Settings → Integrations → Webhooks → Incoming webhook)
# Required permissions: CRM, Tasks, IM
BITRIX_WEBHOOK_URL=https://your-portal.bitrix24.ru/rest/1/your-token/

# Your Bitrix24 portal domain (used to verify outgoing webhook origin)
BITRIX_PORTAL_DOMAIN=your-portal.bitrix24.ru
BITRIX_TIMEOUT_MS=15000

# ─── Bitrix24 Outgoing Webhook ────────────────────────────────────────────────
# Application token from outgoing webhook settings (primary auth method)
BITRIX_OUTGOING_TOKEN=

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# ─── Retry ────────────────────────────────────────────────────────────────────
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=500
RETRY_MAX_DELAY_MS=8000

# ─── Managers (Bitrix24 user IDs) ─────────────────────────────────────────────
MANAGER_IDS_SALES=1,2,3
MANAGER_IDS_TECH=4
MANAGER_IDS_QUALITY=5
MANAGER_IDS_MARKING=6

# ─── SLA deadlines (hours) ────────────────────────────────────────────────────
SLA_P1_HOURS=1
SLA_P2_HOURS=4
SLA_P3_HOURS=8
SLA_P4_HOURS=24
SLA_P5_HOURS=48

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
