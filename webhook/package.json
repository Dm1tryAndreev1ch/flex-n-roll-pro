{
  "name": "flex-n-roll-webhook",
  "version": "2.0.0",
  "description": "Bitrix24 → LM Studio AI webhook handler for FLEX-N-ROLL PRO label typography",
  "main": "src/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --runInBand --forceExit --coverage",
    "lint": "eslint src/ config/ --ext .js",
    "lint:fix": "eslint src/ config/ --ext .js --fix"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "body-parser": "^1.20.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.2.0",
    "openai": "^4.67.3",
    "rate-limit-redis": "^4.2.0",
    "redis": "^4.7.0",
    "winston": "^3.15.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.js"],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": ["src/**/*.js", "config/**/*.js"]
  },
  "nodemonConfig": {
    "watch": ["src/", "config/"],
    "ext": "js,json",
    "ignore": ["logs/", "data/", "node_modules/"]
  },
  "license": "UNLICENSED",
  "private": true
}