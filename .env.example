# =============================================================================
# FLEX-N-ROLL PRO — единый .env
# Скопируйте в .env и заполните реальными значениями
# docker compose автоматически читает .env из корня репозитория
# =============================================================================

# ─── Общее ───────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
LOG_DIR=./logs

# ─── Bitrix24 ─────────────────────────────────────────────────────────────────
# Входящий вебхук (Настройки → Интеграции → Вебхуки → Входящий вебхук)
# Права: CRM + Задачи + IM + Телефония
BITRIX_WEBHOOK_URL=https://your-portal.bitrix24.ru/rest/1/your-token/

# Домен портала (для верификации исходящих событий от Bitrix24)
BITRIX_PORTAL_DOMAIN=your-portal.bitrix24.ru
BITRIX_TIMEOUT_MS=15000

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# Получить токен у @BotFather
BOT_TOKEN=

# Контакт менеджера (показывается клиентам в боте)
MANAGER_CONTACT=@fnr_manager
MANAGER_PHONE=+375XXXXXXXXX

# ─── LM Studio (webhook-сервис) ───────────────────────────────────────────────
# Локальный AI-сервер для классификации обращений
OPENAI_API_KEY=lm-studio
OPENAI_BASE_URL=http://host.docker.internal:1234/v1
OPENAI_MODEL=local-model
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT_MS=30000

# ─── OpenAI (commanalysis) ────────────────────────────────────────────────────
# Настоящий OpenAI API ключ для Whisper + GPT
COMMANALYSIS_OPENAI_API_KEY=sk-...
GPT_MODEL=gpt-4o
WHISPER_MODEL=whisper-1
WHISPER_CHUNK_SIZE_MB=24
DEFAULT_LANGUAGE=ru

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# ─── Retry ────────────────────────────────────────────────────────────────────
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=500
RETRY_MAX_DELAY_MS=8000

# ─── Менеджеры (ID пользователей в Bitrix24) ─────────────────────────────────
MANAGER_IDS_SALES=1,2,3
MANAGER_IDS_TECH=4
MANAGER_IDS_QUALITY=5
MANAGER_IDS_MARKING=6

# ─── SLA дедлайны (часы) ──────────────────────────────────────────────────────
SLA_P1_HOURS=1
SLA_P2_HOURS=4
SLA_P3_HOURS=8
SLA_P4_HOURS=24
SLA_P5_HOURS=48

# ─── Честный ЗНАК / ГИС МТ ───────────────────────────────────────────────────
MDLP_CLIENT_ID=your_client_id
MDLP_CLIENT_SECRET=your_client_secret
MDLP_BASE_URL=https://api.mdlp.crpt.ru
MDLP_TOKEN_URL=https://api.mdlp.crpt.ru/api/v3/true-api/auth/token
MDLP_PARTICIPANT_INN=your_inn
MDLP_DEFAULT_GTIN=your_gtin

# Стадии воронки CRM (CRM → Настройки → Воронки и туннели продаж)
BITRIX_STAGE_PRODUCTION=C3:NEW
BITRIX_STAGE_SHIPMENT=C3:WON
BITRIX_STAGE_MARKING_DONE=C3:PREPARATION
BITRIX_OPERATOR_USER_ID=1
# Секрет для верификации вебхуков marking-сервиса (опционально)
WEBHOOK_SECRET=

# ─── Commanalysis ─────────────────────────────────────────────────────────────
REPORT_MANAGER_USER_ID=1
REPORT_EMAIL=director@flex-n-roll.by
TMP_DIR=/tmp/commanalysis

# ─── Calculator ───────────────────────────────────────────────────────────────
FRONTEND_URL=http://fnr-calculator:80
VITE_APP_TITLE=Калькулятор этикеток flex-n-roll.pro
VITE_API_URL=/api

# ─── Marking — хранилище ──────────────────────────────────────────────────────
DATA_DIR=/app/data
PRODUCTION_DIR=/app/data/production/orders
CODES_DB_PATH=/app/data/codes_db.json

# ─── Разработка ───────────────────────────────────────────────────────────────
# SKIP_VERIFY=true   # Отключить верификацию домена Bitrix24 (только для разработки!)
